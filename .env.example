# Tavily Search API
TAVILY_API_KEY=tvly-xxxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxx

# Custom Model (OpenAI 兼容接口)
CUSTOM_BASE_URL=https://your-api.com/v1
CUSTOM_API_KEY=sk-xxxx
CUSTOM_MODEL_NAME=your-model-name

# Agent Settings
DEFAULT_MODEL=deepseek
EVALUATOR_MODEL=deepseek
QUICK_MAX_ROUNDS=1
STANDARD_MAX_ROUNDS=3
DEEP_MAX_ROUNDS=5
RESULTS_PER_ROUND=8

# App
DATABASE_URL=sqlite:///./data/insight_hub.db
REPORT_OUTPUT_DIR=./reports

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SMTP 邮件配置（用于发送验证码）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-password
SMTP_FROM=your-email@qq.com
